<Window x:Class="ChatBotPOE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CyberBot POE - Cybersecurity Assistant"
        Height="650" 
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <!-- 
        Main window grid layout: 
        3 rows (Header, Content, Footer) and 2 columns (Chat area and Side panel)
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Header / Title -->
            <RowDefinition Height="*"/>
            <!-- Row 1: Main content area -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Input footer -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <!-- Column 0: Chat area (2/3 width) -->
            <ColumnDefinition Width="*"/>
            <!-- Column 1: Side panel (1/3 width) -->
        </Grid.ColumnDefinitions>

        <!-- ============================================ -->
        <!-- HEADER: Application title (Row 0, Span 2 columns) -->
        <!-- ============================================ -->
        <Border Grid.Row="0" 
                Grid.ColumnSpan="2" 
                Background="#2C3E50" 
                Padding="15,10">
            <TextBlock Text="🛡️ CyberBot - Cybersecurity Awareness Assistant"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- ============================================ -->
        <!-- COLUMN 0: CHAT AREA (Row 1, Column 0)        -->
        <!-- ============================================ -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- Chat messages list -->
                <RowDefinition Height="Auto"/>
                <!-- Input area -->
            </Grid.RowDefinitions>

            <!-- Chat History ListBox - Displays all conversation messages -->
            <ListBox x:Name="chatListBox" 
                     Grid.Row="0"
                     Margin="0,0,0,10"
                     FontSize="14"
                     Background="#F8F9FA"
                     BorderBrush="#DEE2E6"
                     BorderThickness="2"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- User Input Panel - TextBox + Send Button -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="userInputTextBox" 
                         Grid.Column="0"
                         Padding="10,8"
                         FontSize="14"
                         Background="White"
                         BorderBrush="#CED4DA"
                         BorderThickness="1"
                         KeyDown="UserInputTextBox_KeyDown"
                         ToolTip="Type your message here. Press Enter to send."/>

                <Button x:Name="sendButton" 
                        Grid.Column="1"
                        Content="Send"
                        Width="80"
                        Margin="10,0,0,0"
                        Padding="10,8"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#007BFF"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SendButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>

        <!-- ============================================ -->
        <!-- COLUMN 1: SIDE PANEL (Row 1, Column 1)       -->
        <!-- ============================================ -->
        <TabControl Grid.Row="1" 
                    Grid.Column="1" 
                    Margin="0,10,10,10"
                    Background="#F8F9FA"
                    BorderBrush="#DEE2E6"
                    BorderThickness="1">

            <!-- TAB 1: TASK MANAGER -->
            <TabItem Header="📋 Tasks" 
                     Background="#E9ECEF">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Instructions -->
                        <RowDefinition Height="*"/>
                        <!-- DataGrid -->
                        <RowDefinition Height="Auto"/>
                        <!-- Action Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Task instructions -->
                    <TextBlock Grid.Row="0"
                               Text="Manage your cybersecurity tasks:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <!-- DataGrid displays tasks from MySQL database -->
                    <DataGrid x:Name="tasksDataGrid" 
                              Grid.Row="1"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Margin="0,0,0,10"
                              Background="White"
                              BorderBrush="#DEE2E6"
                              BorderThickness="1"
                              FontSize="12"
                              RowHeight="30"
                              HeadersVisibility="Column">
                        <DataGrid.Resources>
                            <!-- Style for column headers -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E9ECEF"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>

                    <!-- Action buttons: Refresh, Complete, Delete -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="🔄 Refresh"
                                Padding="12,6"
                                Margin="0,0,10,0"
                                Background="#28A745"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="RefreshTasks_Click"/>

                        <Button Content="✅ Mark Complete"
                                Padding="12,6"
                                Margin="0,0,10,0"
                                Background="#007BFF"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="CompleteTask_Click"
                                ToolTip="Select a task and mark it as completed"/>

                        <Button Content="🗑️ Delete"
                                Padding="12,6"
                                Background="#DC3545"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="DeleteTask_Click"
                                ToolTip="Select a task and permanently delete it"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 2: CYBERSECURITY QUIZ -->
            <TabItem Header="🎯 Quiz" 
                     Background="#E9ECEF">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Question text -->
                        <RowDefinition Height="Auto"/>
                        <!-- Options list -->
                        <RowDefinition Height="Auto"/>
                        <!-- Feedback -->
                        <RowDefinition Height="Auto"/>
                        <!-- Score -->
                        <RowDefinition Height="Auto"/>
                        <!-- Next button -->
                    </Grid.RowDefinitions>

                    <!-- Question display area -->
                    <Border Grid.Row="0"
                            Background="#2C3E50"
                            Padding="15,12"
                            CornerRadius="8"
                            Margin="0,0,0,15">
                        <TextBlock x:Name="quizQuestionText"
                                   Text="Click 'Start Quiz' or type 'start quiz' in chat"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Border>

                    <!-- Answer options list (Multiple Choice or True/False) -->
                    <ListBox x:Name="quizOptionsListBox"
                             Grid.Row="1"
                             Height="150"
                             Margin="0,0,0,10"
                             Background="White"
                             BorderBrush="#DEE2E6"
                             BorderThickness="1"
                             FontSize="14"
                             SelectionChanged="QuizOptionSelected">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E9ECEF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#007BFF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Feedback after answering (Correct/Incorrect + explanation) -->
                    <TextBlock x:Name="quizFeedbackText"
                               Grid.Row="2"
                               Margin="0,0,0,10"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Foreground="#28A745"/>

                    <!-- Score tracker -->
                    <TextBlock x:Name="quizScoreText"
                               Grid.Row="3"
                               Margin="0,0,0,10"
                               FontSize="14"
                               FontWeight="Bold"/>

                    <!-- Next Question / Restart button -->
                    <Button x:Name="nextQuizQuestionButton"
                            Grid.Row="4"
                            Content="Next Question →"
                            Padding="12,8"
                            Background="#17A2B8"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="14"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="NextQuizQuestion_Click"
                            ToolTip="Go to the next quiz question"/>
                </Grid>
            </TabItem>

            <!-- TAB 3: ACTIVITY LOG -->
            <TabItem Header="📜 Activity Log" 
                     Background="#E9ECEF">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Instructions -->
                        <RowDefinition Height="*"/>
                        <!-- Log list -->
                        <RowDefinition Height="Auto"/>
                        <!-- Show More button -->
                    </Grid.RowDefinitions>

                    <!-- Log instructions -->
                    <TextBlock Grid.Row="0"
                               Text="Recent activity log (last 10 actions)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <!-- ListBox showing logged actions with timestamps -->
                    <ListBox x:Name="logListBox"
                             Grid.Row="1"
                             Background="White"
                             BorderBrush="#DEE2E6"
                             BorderThickness="1"
                             FontSize="12"
                             FontFamily="Consolas"
                             Margin="0,0,0,10"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Buttons: Refresh log, Show All -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="🔄 Refresh Log"
                                Padding="12,6"
                                Margin="0,0,10,0"
                                Background="#28A745"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="ShowLog_Click"/>

                        <Button Content="📋 Show All Logs"
                                Padding="12,6"
                                Background="#6C757D"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="ShowLog_Click"
                                ToolTip="Display the full activity history"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ============================================ -->
        <!-- STATUS BAR (Row 2, Span 2 columns)           -->
        <!-- ============================================ -->
        <StatusBar Grid.Row="2" 
                   Grid.ColumnSpan="2" 
                   Background="#2C3E50"
                   Height="30">
            <StatusBarItem>
                <TextBlock Foreground="White" 
                           FontSize="12">
                    🟢 Connected to MySQL | Type 'help' for commands | Say 'start quiz' to test your knowledge
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
